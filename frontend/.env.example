# Nuxt frontend environment — copy to .env
# Base URL of the versioned Laravel API.
NUXT_PUBLIC_API_BASE=http://localhost:8000/api/v1

# Public site URL (used in canonical/OG tags + sitemap).
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp click-to-chat number (intl, digits only).
NUXT_PUBLIC_WHATSAPP=9771XXXXXXX

# Analytics (optional).
NUXT_PUBLIC_GTM_ID=
NUXT_PUBLIC_GA_ID=
NUXT_PUBLIC_GOOGLE_PLACE_ID=
