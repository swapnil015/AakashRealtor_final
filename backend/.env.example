# ─────────────────────────────────────────────────────────────
#  Aakash Realtor API — environment template
#  Copy to `.env` then run:  php artisan key:generate
# ─────────────────────────────────────────────────────────────

APP_NAME="Aakash Realtor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kathmandu
APP_URL=http://localhost:8000

# Public URL of the Nuxt frontend (used in mail links, CORS, redirects)
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Logging ──────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ── Database (PostgreSQL) ────────────────────────────────────
# Requires the pdo_pgsql PHP extension to be enabled.
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=aakash_realtor
DB_USERNAME=postgres
DB_PASSWORD=

# ── Session / Cache / Queue ──────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

CACHE_STORE=database
QUEUE_CONNECTION=database          # switch to "redis" in production

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Sanctum / Auth ───────────────────────────────────────────
# Comma-separated list of SPA domains that may receive the auth cookie.
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
# Personal access token expiry in minutes (null = never expire).
SANCTUM_TOKEN_EXPIRATION=
# Throttle: max login/register attempts per minute, per IP.
AUTH_RATE_LIMIT=5

# ── CORS ─────────────────────────────────────────────────────
# Origins allowed to call the API (Nuxt web + mobile dev tunnels).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://aakashrealtor.com,https://www.aakashrealtor.com

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@aakashrealtor.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Media storage ────────────────────────────────────────────
# Driver used for property images: "cloudinary" | "s3" | "public"
MEDIA_DISK=cloudinary
MAX_IMAGES_PER_LISTING=20

# Cloudinary  (cloudinary://API_KEY:API_SECRET@CLOUD_NAME)
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# AWS S3 (alternative to Cloudinary)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Integrations ─────────────────────────────────────────────
# WhatsApp click-to-chat number (intl format, digits only) + optional Cloud API
WHATSAPP_PHONE=9771xxxxxxx
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=

# Frontend analytics (read by Nuxt at build time; documented here for parity)
GOOGLE_TAG_MANAGER_ID=
GOOGLE_ANALYTICS_ID=
GOOGLE_PLACE_ID=

# ── Error monitoring ─────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# ── Search ───────────────────────────────────────────────────
# "pgsql" = built-in tsvector full-text search; "meilisearch" for scale.
SCOUT_DRIVER=pgsql
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
