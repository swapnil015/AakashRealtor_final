# ═════════════════════════════════════════════════════════════════════════════
#  api.env.production.example — Laravel API production environment
#
#  USAGE:
#    1. Copy to ./env/api.env.production   (this real file is git-ignored)
#    2. Fill in EVERY value marked CHANGE_ME / generate-me.
#    3. Generate APP_KEY:   docker compose run --rm api php artisan key:generate --show
#       (paste the "base64:..." output below).
#
#  This file is loaded by the `api` and `worker` services (env_file in compose).
#  Several values (DB_*, REDIS_*, NUXT_PUBLIC_API_BASE) are ALSO read by compose
#  itself from the shell/.env — keep them consistent.
# ═════════════════════════════════════════════════════════════════════════════

APP_NAME="Aakash Realtor"
APP_ENV=production
# base64:... — generate with `php artisan key:generate --show`. NEVER reuse dev key.
APP_KEY=CHANGE_ME_base64_key
# MUST be false in production — true leaks stack traces & config to clients.
APP_DEBUG=false
APP_TIMEZONE=Asia/Kathmandu
APP_URL=https://api.aakashrealtor.com

# Public URL of the Nuxt site — used in mail links, password resets, redirects.
FRONTEND_URL=https://aakashrealtor.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Logging ──────────────────────────────────────────────────────────────────
# "stderr" so Docker captures logs; pair with Sentry for error aggregation.
LOG_CHANNEL=stack
LOG_STACK=stderr
LOG_LEVEL=warning

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# DB_HOST is the compose service name "postgres" (NOT 127.0.0.1).
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=aakash_realtor
DB_USERNAME=aakash
DB_PASSWORD=CHANGE_ME_strong_db_password

# ── Session / Cache / Queue → Redis in production ────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
# Cookie domain so the SPA + API can share the Sanctum cookie across subdomains.
SESSION_DOMAIN=.aakashrealtor.com

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# REDIS_HOST is the compose service name "redis".
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT=6379

# ── Sanctum / Auth ───────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=aakashrealtor.com,www.aakashrealtor.com
SANCTUM_TOKEN_EXPIRATION=
AUTH_RATE_LIMIT=5

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://aakashrealtor.com,https://www.aakashrealtor.com

# ── Mail (transactional) ─────────────────────────────────────────────────────
# Use a real provider (Postmark, SES, Mailgun, Resend...). Example: SMTP.
MAIL_MAILER=smtp
MAIL_HOST=CHANGE_ME_smtp_host
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@aakashrealtor.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Media storage (Cloudinary recommended — durable, off-host) ───────────────
MEDIA_DISK=cloudinary
MAX_IMAGES_PER_LISTING=20
# cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=CHANGE_ME
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_UPLOAD_PRESET=

# AWS S3 (alternative to Cloudinary — set MEDIA_DISK=s3 to use)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Integrations ─────────────────────────────────────────────────────────────
WHATSAPP_PHONE=9771xxxxxxx
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_PHONE_ID=

GOOGLE_TAG_MANAGER_ID=
GOOGLE_ANALYTICS_ID=
GOOGLE_PLACE_ID=

# ── Error monitoring (Sentry) ────────────────────────────────────────────────
# From Sentry project settings → Client Keys (DSN). Empty = disabled.
SENTRY_LARAVEL_DSN=CHANGE_ME_or_leave_empty
# Lower the trace sample rate in production to control cost (0.0–1.0).
SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Search ───────────────────────────────────────────────────────────────────
SCOUT_DRIVER=pgsql
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
