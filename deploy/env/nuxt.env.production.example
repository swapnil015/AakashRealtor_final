# ═════════════════════════════════════════════════════════════════════════════
#  nuxt.env.production.example — Nuxt 3 SSR runtime environment
#
#  USAGE:  copy to ./env/nuxt.env.production  (git-ignored), fill values.
#
#  IMPORTANT — build-time vs runtime:
#    • NUXT_PUBLIC_* values that must appear in the CLIENT bundle are baked at
#      BUILD time. NUXT_PUBLIC_API_BASE is therefore ALSO passed as a Docker
#      build arg (see docker-compose.yml `nuxt.build.args`). Keep both in sync.
#    • Values consumed only by the SSR server at runtime (private runtimeConfig)
#      are read from this env_file when the container starts.
# ═════════════════════════════════════════════════════════════════════════════

NODE_ENV=production
# Nitro server bind (matches Dockerfile.nuxt). Leave as-is.
HOST=0.0.0.0
PORT=3000

# ── Public API base (client + server) ────────────────────────────────────────
# The browser and SSR both call the API at this URL. Must match the compose
# build arg NUXT_PUBLIC_API_BASE.
NUXT_PUBLIC_API_BASE=https://api.aakashrealtor.com/api/v1

# Public site URL (canonical, used for SEO/meta/sitemaps).
NUXT_PUBLIC_SITE_URL=https://aakashrealtor.com

# ── Analytics / tags (public) ────────────────────────────────────────────────
NUXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=
NUXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ── WhatsApp click-to-chat (public) ──────────────────────────────────────────
NUXT_PUBLIC_WHATSAPP_PHONE=9771xxxxxxx

# ── Sentry (frontend, @sentry/nuxt) ──────────────────────────────────────────
# Public DSN for browser + SSR error reporting. Empty = disabled.
NUXT_PUBLIC_SENTRY_DSN=CHANGE_ME_or_leave_empty
NUXT_PUBLIC_SENTRY_ENVIRONMENT=production
# Auth token used ONLY at build time to upload source maps (keep server-side).
SENTRY_AUTH_TOKEN=CHANGE_ME_or_leave_empty
SENTRY_ORG=CHANGE_ME
SENTRY_PROJECT=aakash-realtor-web
